# MTProto (Telegram) proxy secret (generate: mtg generate-secret --hex vk.com)
MTG_SECRET=

# Xray VLESS UUID for client auth
XRAY_UUID=

# Xray Reality keys (generate via: xray x25519)
XRAY_PRIVATE_KEY=
XRAY_PUBLIC_KEY=

# Shadowsocks password (generate via: openssl rand -base64 16)
SS_PASSWORD=

# Reality TLS camouflage domain (must exist and have HTTPS)
REALITY_SERVER_NAME=vk.com
